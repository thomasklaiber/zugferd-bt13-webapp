# Wird vom Hostinger Docker Manager automatisch gesetzt.
# Für lokale Tests hier manuell eintragen.

# Projektname = ergibt die Subdomain: zugferd-bt13.deinedomain.tld
COMPOSE_PROJECT_NAME=zugferd-bt13

# Deine Domain (ohne Subdomain), z.B. deinedomain.tld
# Wird von Hostinger automatisch aus der Traefik-Konfiguration übernommen.
TRAEFIK_HOST=deinedomain.tld
